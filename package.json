{
  "name": "blog-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-content": "node scripts/sync-content-assets.mjs",
    "sync-content:dev": "DRAFT_PREVIEW=1 node scripts/sync-content-assets.mjs",
    "publish-content": "bash scripts/publish-content.sh",
    "dev:next": "next dev",
    "dev:watch": "DRAFT_PREVIEW=1 node scripts/dev-watch.mjs",
    "dev": "pnpm sync-content:dev && concurrently --kill-others --names \"next,watch\" --prefix-colors \"cyan,green\" \"pnpm dev:next\" \"pnpm dev:watch\"",
    "build": "pnpm sync-content && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@shikijs/rehype": "^4.1.0",
    "@vercel/analytics": "^2.0.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.5",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
